pipeline {
    agent { 
        docker { 
            image 'gradle:jdk17'
            // This part handles the CACHING part of your assignment
            args '-v /var/jenkins_home/.gradle:/home/gradle/.gradle'
        } 
    }
    stages {
        stage('Validate Branch') {
            steps {
                script {
                    // This handles the CONDITIONAL branch logic
                    if (env.BRANCH_NAME != 'main' && !env.BRANCH_NAME.contains('feature')) {
                        error "Pipeline failed: Branch '${env.BRANCH_NAME}' is not allowed."
                    }
                }
            }
        }
        stage('CodeCoverage') {
            when { branch 'main' } // ONLY on main
            steps { sh './gradlew jacocoTestReport' }
        }
        stage('Run Tests') {
            when {
                allOf {
                    branch 'feature*'
                    not { branch 'main' }
                }
            }
            steps { sh './gradlew test' } // ONLY on feature branches
        }
    }
}
